import React, { useEffect, useRef } from 'react'
import * as $3Dmol from '3dmol'   // npm i 3dmol

export default function Viewer3D({ pdbUrl }:{pdbUrl:string }) {
  const viewerRef = useRef<HTMLDivElement>(null)

  useEffect(()=>{
    if(!viewerRef.current || !pdbUrl) return

    const element = viewerRef.current
    element.innerHTML = ''
    const viewer = ($3Dmol as any).createViewer(element,{backgroundColor:'#fff'})
    viewer.addModelFromFile(pdbUrl,'pdb')
    viewer.setStyle({cartoon:{color:'spectrum'}})
    viewer.zoomTo(); viewer.render()
  },[pdbUrl])

  return (
    <div
      ref={viewerRef}
      style={{width:'100%',height:400,border:'1px solid #e5e7eb',borderRadius:8}}
    />
  )
}
